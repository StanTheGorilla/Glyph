{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Glyph",
  "version": "0.1.5",
  "identifier": "com.glyph.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "node scripts/prepare-sidecars.mjs && npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Glyph",
        "width": 880,
        "height": 720,
        "minWidth": 720,
        "minHeight": 600,
        "resizable": true,
        "visible": true,
        "url": "/"
      },
      {
        "label": "hud",
        "title": "Glyph HUD",
        "width": 120,
        "height": 120,
        "url": "/hud",
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "shadow": false,
        "focus": false,
        "visible": false
      }
    ],
    "trayIcon": {
      "id": "glyph-tray",
      "iconPath": "icons/icon.ico",
      "tooltip": "Glyph — voice dictation"
    },
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "externalBin": [
      "binaries/glyph-asr-sidecar",
      "binaries/glyph-whisper-sidecar"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/StanTheGorilla/Glyph/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDhDOTY3QTkzRUYxRDcwMTgKUldRWWNCM3ZrM3FXakVVelRQUldHUXUxYzdFUDF5OFI1RGZsZmxQbTRtN05PdndpVTBQZ2Y3aDkK"
    }
  }
}
